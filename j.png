html {
  font-size: 10px;
}
body {
  margin: 0%;
}
.navbar {
  display: flex;
  justify-content: space-between;
  border-bottom: solid 0.1rem grey;
}

.navbar-enroll-button,
.navbar-enroll-button:link,
.navbar-enroll-button:visited {
  width: 20rem;
  height: 6rem;
  background-color: rgb(69, 69, 213);
  border: 0;
  border-radius: 10px;
  cursor: pointer;
  padding-bottom: 2px;
  display: inline-block;
  transition: all 0.3s;
}
.navbar-enroll-button:hover {
  background-color: rgb(144, 144, 208);
}
.navbar-enroll-button a {
  color: white;
  font-size: 2.5rem;
  font-family: sans-serif;
  text-decoration: none;
  cursor: pointer;
}
.nav-ul {
  list-style: none;
  font-size: 2rem;
  gap: 5rem;
  display: flex;
  justify-content: center;
  padding-right: 4rem;
  align-items: center;
}
.hero-section {
  padding: 10rem 2rem;
  background-image: url(background-img.png);
  background-size: cover;
  padding-bottom: 15rem;
  margin-bottom: 10rem;
}
.nav-logo {
  height: 10rem;
}
.nav-logo-box {
}
.hero-section h1 {
  color: #fff;
  font-size: 4.5rem;
  font-family: sans-serif;
  margin: 0;
}
.paragraph-one {
  color: #b5b1b1;
  line-height: 1.5;
  margin: 0;
  font-size: 2.5rem;
  font-family: sans-serif;
}
.paragraph-two {
  color: #b5b1b1;
  margin-top: 0;
  margin-bottom: 4rem;
  line-height: 2;
  font-size: 2.5rem;
  font-family: sans-serif;
}
.alink {
  color: blue;

  font-size: 2.5rem;
  font-family: sans-serif;
  text-decoration: none;
  cursor: pointer;
}
.nav-link:link,
.nav-link:visited {
  color: #002942;
  font-size: 2.5rem;
  font-family: sans-serif;
  text-decoration: none;
  cursor: pointer;
}

.nav-link:hover,
.nav-link:active {
  color: blue;
}
.hero-btn,
.hero-btn:link,
.hero-btn:visited {
  width: 20rem;
  height: 6rem;
  background-color: rgb(69, 69, 213);
  border: 0;
  border-radius: 10px;
  cursor: pointer;

  padding-bottom: 2px;
  display: inline-block;
  transition: all 0.3s;
}

.hero-btn:hover {
  background-color: rgb(144, 144, 208);
}
.hero-btn a {
  color: white;
  font-family: sans-serif;
  font-size: 1.5rem;
  text-decoration: none;
}
.feature-heading {
  text-align: center;
  font-size: 3rem;
  font-family: sans-serif;
  color: #555;
}
.grid--4-col {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 1.5rem;
  justify-content: space-around;
  padding: 0 1.5rem 20rem 1.5rem;
}
.feature-img {
  width: 100%;
  height: 70%;
  object-fit: cover;
  transition: 0.5s ease;
}

.feature-img:hover {
  transform: scale(1.1);
}
.feature-box {
  box-shadow: 0 2.4rem 4.8rem rgba(0, 0, 0, 0.075);
  border-radius: 11px;
  overflow: hidden;
  height: 50.5rem;
}
.features-title {
  font-size: 1.5rem;
  font-family: sans-serif;

  text-transform: uppercase;
}
.box {
  font-size: 1.7rem;
  margin: 0%;
  padding: 0;
}
.feature-text {
  font-size: 1.7rem;
  margin: 0%;
  padding: 0rem 1rem 1.9rem 1.9rem;
}
.feature-text-box {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.footer-box {
  padding-bottom: 10rem;
  background-color: #01253b;
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
}
.footer-box h5 {
  font-size: 2rem;
  margin-top: 2.7rem;
}
.footer-p {
  font-family: sans-serif;
  color: #d0c4c4;
  font-weight: 800;
  font-size: 1.5rem;
  padding: 0 15rem 2rem 3rem;
  margin-top: 0;
}
.quick-links {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}
article h4,
h5 {
  text-transform: uppercase;
  color: #fff;
  font-size: 2rem;
  font-family: sans-serif;
}
article a {
  font-size: 2rem;
  color: #fff;
  text-decoration: none;
}
article a:hover {
  color: #d2d1d1;
}
hr {
  font-size: 2rem;
}
.all-right-reserve {
  text-align: center;
  font-size: 1.5rem;
  color: white;
  padding: 2rem;
}
footer {
  background-color: #01253b;
}
.social-icon {
  width: 5rem;
  height: 5rem;
  background-color: #fff;
  border-radius: 10px;
}
.facebook {
  color: blue;
  background-color: #fff;
  border-radius: 10px;
}
.instagram {
  color: red;
  background-color: #fff;
  border-radius: 10px;
}
.youtube {
  border-radius: 10px;
  color: red;
}
.follow-us {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}
.learn-more {
  color: #002942;
}

@media (max-width: 768px) {
  .nav-ul {
    gap: 2rem;
    padding-right: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .nav-logo {
    height: 7rem;
  }

  .grid--4-col {
    grid-template-columns: repeat(2, 1fr);
    padding: 0 1.5rem 10rem 1.5rem;
  }

  .feature-box {
    height: auto;
    min-height: 40rem;
  }

  .footer-box {
    grid-template-columns: 1fr 1fr;
    padding-bottom: 5rem;
  }

  .footer-p {
    padding: 0 2rem 2rem 3rem;
  }
}

@media (max-width: 480px) {
  .navbar {
    flex-direction: column;
    align-items: center;
    padding: 1rem;
  }

  .nav-ul {
    flex-direction: column;
    gap: 1.5rem;
    padding: 1rem 0;
    align-items: center;
  }

  .nav-logo {
    height: 6rem;
  }

  .navbar-enroll-button {
    width: 18rem;
    height: 5rem;
  }

  .navbar-enroll-button a {
    font-size: 1.8rem;
  }

  .feature-heading {
    font-size: 2.4rem;
  }

  .grid--4-col {
    grid-template-columns: 1fr;
    padding: 0 1rem 6rem 1rem;
    gap: 2rem;
  }

  .feature-box {
    height: auto;
  }

  .feature-img {
    height: 20rem;
  }

  .features-title {
    font-size: 1.8rem;
    text-align: center;
  }

  .box,
  .feature-text {
    font-size: 1.6rem;
    text-align: center;
    padding: 0 1rem 1rem 1rem;
  }

  .learn-more {
    font-size: 1.6rem;
    margin-bottom: 1.5rem;
  }

  /* Footer */
  .footer-box {
    grid-template-columns: 1fr;
    padding: 3rem 2rem 4rem 2rem;
    text-align: center;
  }

  .footer-p {
    padding: 0 1rem 1.5rem 1rem;
  }

  .quick-links {
    align-items: center;
  }

  .follow-us {
    align-items: center;
    flex-direction: row;
    justify-content: center;
    flex-wrap: wrap;
  }

  .social-icon {
    width: 4rem;
    height: 4rem;
  }

  .all-right-reserve {
    font-size: 1.3rem;
  }
}
